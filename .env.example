# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Redshift → Fabric DDL Converter"
APP_VERSION="1.0.0"
DEBUG=false
LOG_LEVEL=INFO

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=["*"]

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=data/uploads
OUTPUT_DIR=data/outputs
REPORTS_DIR=data/reports
LOGS_DIR=data/logs
MAX_UPLOAD_SIZE_MB=50

# ── Fabric Parameterisation ───────────────────────────────────────────────────
# These placeholders appear in the generated Fabric T-SQL DDL.
# Edit to match your Flyway/deployment variable names.
FLYWAY_SCHEMA_PLACEHOLDER=${schema}
OUTPUT_SCHEMA_PLACEHOLDER=${os_bi_alefdw}

# ── Conversion Behaviour ──────────────────────────────────────────────────────
STRIP_TABLE_SUFFIXES_IN_VIEWS=true
